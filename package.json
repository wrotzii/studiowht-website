    "@radix-ui/react-toast": "^1.2.15",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "framer-motion": "^12.35.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "multer": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
